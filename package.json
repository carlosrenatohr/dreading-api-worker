{
  "name": "dreading-api-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Cloudflare Worker (Hono + D1) serving the Catholic daily readings.",
  "scripts": {
    "dev": "wrangler dev",
    "migrate:local": "wrangler d1 migrations apply dreading --local",
    "migrate:remote": "wrangler d1 migrations apply dreading --remote",
    "test": "vitest run",
    "deploy": "wrangler deploy"
  },
  "dependencies": {
    "hono": "^4.6.14",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8",
    "wrangler": "^3.90.0"
  }
}
